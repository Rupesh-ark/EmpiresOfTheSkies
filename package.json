{
  "name": "empires-of-the-skies-root",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "dev:app": "pnpm --filter empires_of_the_skies dev",
    "dev:server": "pnpm --filter empires-server dev",
    "dev:game": "pnpm --filter @eots/game watch",
    "start:server": "pnpm --filter empires-server start",
    "build:all": "pnpm --filter @eots/game build && pnpm --filter empires-server build && pnpm --filter empires_of_the_skies build"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}