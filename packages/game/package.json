{
  "name": "@eots/game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json -w --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "boardgame.io": "0.51.0-beta.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  }
}
