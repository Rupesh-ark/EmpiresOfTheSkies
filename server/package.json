{
  "name": "empires-server",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:log": "mkdir -p logs && tsx watch src/server.ts 2>&1 | tee logs/game.log",
    "build": "tsc -p src/tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@eots/game": "workspace:*",
    "@koa/cors": "^5.0.0",
    "bgio-postgres": "^1.0.16",
    "boardgame.io": "0.51.0-beta.4",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/koa": "^3.0.1",
    "@types/koa__cors": "^5.0.1",
    "@types/node": "^22.19.11",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
