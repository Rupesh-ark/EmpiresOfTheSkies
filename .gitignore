# --- dependencies (both root + nested packages) ---
**/node_modules/
**/.pnpm-store/

# --- boardgame.io FlatFile persistence ---
server/storage/

# --- build outputs (Vite + server builds) ---
**/dist/
**/dist-ssr/
**/build/
**/build-server/


# --- local overrides ---
**/*.local

# --- logs ---
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# --- coverage ---
**/coverage/

# --- TS / tooling caches ---
**/*.tsbuildinfo

# --- IDE / OS ---
**/.vscode/*
!**/.vscode/extensions.json
**/.idea/
**/.DS_Store
**/*.suo
**/*.ntvs
**/*.njsproj
**/*.sln
**/*.sw?

# env files (Vite / Node)
**/.env
**/.env.*
**/.env.*.local

.*
!.gitignore

/research
/feedback
/docs

# Bot weights local overrides (JSON, not committed)
packages/game/src/ai/weightsConfig.local.json
packages/game/src/ai/tournament-results/
bot-logs/
bot-training/

# Bot analytics intermediate outputs & generated docs
packages/game/src/ai/analytics/*.json
packages/game/src/ai/docs/*
packages/game/tuner_results/*
